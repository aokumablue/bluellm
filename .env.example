# bluellm 環境変数の例 — config.yml.example の os.environ/ 参照と対応
#
# 使い方:
#   cp .env.example .env   # 値を埋める
#   .env は決してコミットしないこと（秘密情報）
#
# config.yml 側で `key: os.environ/OPENAI_API_KEY_A` のように参照する名前と、
# ここで定義する変数名を一致させる。

# ── 認証・暗号 ─────────────────────────────────────────────────────
# クライアントが提示する master key（16文字以上。例: openssl rand -base64 24）。
# ローカル単一利用で認証不要なら空のままでよい（config の generals.key も省略）。
BLUELLM_MASTER_KEY=
# encrypted: 設定値の復号に使う salt key（暗号化値を使う場合のみ・16文字以上）。
BLUELLM_SALT_KEY=

# ── プロバイダー API キー ──────────────────────────────────────────
# OpenAI 互換ノード（ラウンドロビン用に複数エンドポイント分）
OPENAI_API_KEY_A=
OPENAI_API_KEY_B=
OPENAI_API_KEY_C=

# Azure OpenAI（リージョン別エンドポイント分）
AZURE_API_KEY_EASTUS=
AZURE_API_KEY_WESTUS=

# ── 任意 ───────────────────────────────────────────────────────────
# 設定ファイルパスの上書き（既定はパッケージ既定パス）
# BLUELLM_CONFIG=./config.yml
